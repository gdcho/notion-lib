{
  "manifest_version": 3,
  "name": "notion library: auto-save books to Notion",
  "description": "Browse a book on Google Books, click the extension, and save the title, author, ISBN, and cover to your Notion database.",
  "version": "2.0.0",
  "permissions": ["storage"],
  "host_permissions": ["https://*/*"],
  "action": {
    "default_popup": "index.html",
    "default_icon": "book.png",
    "default_title": "notion library"
  },
  "icons": {
    "16": "book.png",
    "48": "book.png",
    "128": "book.png"
  },
  "background": {
    "service_worker": "background.js"
  },
  "content_scripts": [
    {
      "matches": ["<all_urls>"],
      "js": ["contentScript.js"]
    }
  ]
}
